{
    "name": "phpdup/phpdup",
    "description": "AST-based PHP duplicate-logic detector and refactoring assistant.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-hash": "*",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^6.4 || ^7.0",
        "sebastian/diff": "^5.1 || ^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Phpdup\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phpdup\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/phpdup"],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "bin/phpdup analyze"
    }
}
