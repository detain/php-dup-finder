{
    "_description": "Medoo-specific DB symbol equivalence pack (option 4 of docs/plans/orm-db-semantic-dedup.md). Extends the stock DbOpRegistry with Medoo method names. Medoo is a lightweight PHP database framework supporting MySQL, MSSQL, SQLite, PostgreSQL and more. It provides a simple ActiveRecord-like API. Use with --profile=db-aware-medoo together with --db-aware to fold Medoo call shapes into the same canonical __DB_<OP>__ tokens as the rest of the recognised DB ecosystem. See https://medoo.in",
    "db_symbols": {
        "methods": {
            "select":         "db.read",
            "find":           "db.read",
            "findone":        "db.read",
            "findall":        "db.read",
            "get":            "db.read",
            "has":            "db.read",
            "hash":           "db.read",
            "count":          "db.read",
            "max":            "db.read",
            "min":            "db.read",
            "avg":            "db.read",
            "sum":            "db.read",
            "column":         "db.read",
            "var":            "db.read",
            "insert":         "db.write",
            "update":         "db.write",
            "delete":         "db.delete",
            "replace":        "db.write",
            "create":         "db.write",
            "drop":           "db.delete",
            "alter":          "db.write",
            "truncate":       "db.delete",
            "show":           "db.read",
            "describe":       "db.read",
            "query":          "db.query",
            "exec":           "db.execute",
            "distinct":       "db.read",
            "from":           "db.read",
            "join":           "db.read",
            "where":          "db.read",
            "group":          "db.read",
            "order":          "db.read",
            "having":         "db.read",
            "limit":          "db.read",
            "offset":         "db.read",
            "rand":           "db.read",
            "command":        "db.execute"
        }
    }
}
