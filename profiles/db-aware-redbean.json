{
    "_description": "RedBeanPHP-specific DB symbol equivalence pack (option 4 of docs/plans/orm-db-semantic-dedup.md). Extends the stock DbOpRegistry with RedBeanPHP method names. RedBeanPHP is a popular PHP ORM known for its 'zero-config' philosophy and automatic database schema management. Use with --profile=db-aware-redbean together with --db-aware to fold RedBeanPHP call shapes into the same canonical __DB_<OP>__ tokens as the rest of the recognised DB ecosystem. See https://redbeanphp.com/",
    "db_symbols": {
        "methods": {
            "find":             "db.read",
            "findone":          "db.read",
            "findorcreate":     "db.write",
            "findall":          "db.read",
            "findlike":         "db.read",
            "findeach":         "db.read",
            "findallby":        "db.read",
            "findoneby":        "db.read",
            "dispense":         "db.write",
            "store":            "db.write",
            "trash":            "db.delete",
            "save":             "db.write",
            "update":           "db.write",
            "delete":           "db.delete",
            "load":             "db.read",
            "wipe":             "db.delete",
            "related":          "db.read",
            "dependson":        "db.read",
            "clearrelation":    "db.write",
            "unrelate":         "db.write",
            "relate":           "db.write",
            "fetchas":          "db.read",
            "with":             "db.read",
            "withcondition":    "db.read",
            "withsql":          "db.read",
            "alias":            "db.read",
            "join":             "db.read",
            "distinct":         "db.read",
            "limit":            "db.read",
            "order":            "db.read",
            "page":             "db.read",
            "count":            "db.read",
            "avg":              "db.read",
            "min":              "db.read",
            "max":              "db.read",
            "sum":              "db.read",
            "exportsql":        "db.read",
            "import":           "db.write",
            "importrow":        "db.write",
            "batch":            "db.read",
            "graph":            "db.write",
            "transaction":      "db.execute",
            "begin":            "db.execute",
            "commit":           "db.execute",
            "rollback":         "db.execute"
        }
    }
}
