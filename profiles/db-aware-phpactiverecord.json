{
    "_description": "PHP ActiveRecord-specific DB symbol equivalence pack (option 4 of docs/plans/orm-db-semantic-dedup.md). Extends the stock DbOpRegistry with PHP ActiveRecord method names. PHP ActiveRecord is an implementation of the ActiveRecord pattern for PHP. Use with --profile=db-aware-phpactiverecord together with --db-aware to fold PHP ActiveRecord call shapes into the same canonical __DB_<OP>__ tokens as the rest of the recognised DB ecosystem. See http://www.phpactiverecord.org/",
    "db_symbols": {
        "methods": {
            "find":               "db.read",
            "findby_sql":         "db.read",
            "findbypk":           "db.read",
            "findall":            "db.read",
            "findfirst":          "db.read",
            "findlast":           "db.read",
            "all":                "db.read",
            "first":              "db.read",
            "last":               "db.read",
            "exists":             "db.read",
            "count":              "db.read",
            "sum":                "db.read",
            "average":            "db.read",
            "minimum":            "db.read",
            "maximum":            "db.read",
            "pluck":              "db.read",
            "select":             "db.read",
            "from":               "db.read",
            "where":              "db.read",
            "order":              "db.read",
            "group":              "db.read",
            "having":             "db.read",
            "limit":              "db.read",
            "offset":             "db.read",
            "join":               "db.read",
            "includes":           "db.read",
            "distinct":           "db.read",
            "create":             "db.write",
            "new":                "db.write",
            "save":               "db.write",
            "update":             "db.write",
            "updateattributes":   "db.write",
            "updatecolumn":       "db.write",
            "updatecolumns":      "db.write",
            "delete":             "db.delete",
            "destroy":            "db.delete",
            "deleteall":          "db.delete",
            "destroyall":         "db.delete",
            "reload":             "db.read",
            "refresh":            "db.read",
            "transaction":        "db.execute"
        }
    }
}
