{
    "_description": "Pixie Query Builder-specific DB symbol equivalence pack (option 4 of docs/plans/orm-db-semantic-dedup.md). Extends the stock DbOpRegistry with Pixie method names. Pixie is a lightweight PHP query builder based on Laravel's Eloquent, supporting MySQL, PostgreSQL, SQLite and more. Use with --profile=db-aware-pixie together with --db-aware. See https://github.com/usmanhalalit/pixie",
    "db_symbols": {
        "methods": {
            "table":           "db.read",
            "select":          "db.read",
            "from":            "db.read",
            "join":            "db.read",
            "leftJoin":        "db.read",
            "rightJoin":       "db.read",
            "joinWhere":       "db.read",
            "where":           "db.read",
            "orWhere":         "db.read",
            "whereIn":         "db.read",
            "orWhereIn":       "db.read",
            "whereNotIn":      "db.read",
            "orWhereNotIn":    "db.read",
            "whereNull":       "db.read",
            "orWhereNull":     "db.read",
            "whereNotNull":    "db.read",
            "orWhereNotNull":  "db.read",
            "whereBetween":    "db.read",
            "orWhereBetween":  "db.read",
            "groupBy":         "db.read",
            "orderBy":         "db.read",
            "having":          "db.read",
            "orHaving":        "db.read",
            "order":           "db.read",
            "limit":           "db.read",
            "offset":          "db.read",
            "page":            "db.read",
            "get":             "db.read",
            "first":           "db.read",
            "count":           "db.read",
            "insert":          "db.write",
            "insertGetId":     "db.write",
            "update":          "db.write",
            "updateOrInsert":  "db.write",
            "delete":          "db.delete",
            "truncate":        "db.delete",
            "raw":             "db.query",
            "increment":       "db.write",
            "decrement":       "db.write"
        }
    }
}
